# ==========================================
# Universal Multi-Agent Simulation Engine
# Environment Configuration Template
# ==========================================

# ------------------------------------------
# 1. Primary LLM Provider API Keys
# ------------------------------------------

# Google Gemini API Key (Recommended for 2026 Architecture)
# Required for Context Caching (Token Saving Tech #1) and true Thinking Level Routing
GEMINI_API_KEY="your_gemini_api_key_here"

# OpenAI API Key (For o3-mini/gpt-4o-mini fallbacks)
OPENAI_API_KEY="your_openai_api_key_here"

# Anthropic API Key (For Claude models)
ANTHROPIC_API_KEY="your_anthropic_api_key_here"

# DeepSeek API Key (For high-inference cost performance)
DEEPSEEK_API_KEY="your_deepseek_api_key_here"

# ------------------------------------------
# 2. Local/Self-Hosted LLM Configuration
# ------------------------------------------

# For Ollama natively hosted instances
# OLLAMA_BASE_URL="http://localhost:11434/v1"

# Any generic OpenAI-compatible endpoint (vLLM, LMStudio, etc.)
# CUSTOM_API_BASE_URL="http://your_custom_url/v1"
# CUSTOM_API_KEY="your_custom_api_key"

# ------------------------------------------
# 3. Memory & Database (Optional Extensions)
# ------------------------------------------
# MongoDB URL for Persistent Identity Core / World State saving 
# MONGO_URI="mongodb://localhost:27017/"

# Qdrant/Pinecone Vector DB for true Vector Search in SALM
# VECTOR_DB_API_KEY="your_vector_db_key_here"
